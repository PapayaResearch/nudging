d$uncovered_values
d$uncovered_values %>% gsub("[\[\]]", "", .)
d$uncovered_values %>% gsub("[\\[\\]]", "", .)
d$uncovered_values %>% gsub("[", "", .)
d$uncovered_values %>% gsub("\\[", "", .)
d$uncovered_values %>% gsub("(\\[|\\])", "", .)
d$uncovered_values %>% gsub("(\\[|\\])", "", .) %>% str_split(",")
d$uncovered_values %>% gsub("(\\[|\\])", "", .) %>% str_split(", ")
d$uncovered_values %>% gsub("(\\[|\\])", "", .) %>% str_split(", ") %>% apply(length)
d$uncovered_values %>% gsub("(\\[|\\])", "", .) %>% str_split(", ") %>% lapply(length)
d$uncovered_values %>% gsub("(\\[|\\])", "", .) %>% str_split(", ") %>% tapply(length)
d$uncovered_values %>% gsub("(\\[|\\])", "", .) %>% str_split(", ") %>% sapply(length)
d <- d %>% mutate(
n_uncovered = uncovered_values %>% gsub("(\\[|\\])", "", .) %>% str_split(", ") %>% sapply(length)
)
d %>% ggplot(aes(trial_nudge, n_uncovered, color = source, fill = source)) +
